{
  "name": "@campfire/app",
  "version": "0.0.1",
  "description": "Campfire browser shell and local runtime: Vite integration, virtual modules, presentation modes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ilyichv/campfire.git",
    "directory": "packages/app"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
