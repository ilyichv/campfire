  "dependencies": {
    "@campfire/core": "workspace:*",
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@campfire/typescript-config": "workspace:*",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  }
